TO CONNECT:
psql -h db.doc.ic.ac.uk -p 5432 -U at2225
Then type password in ~/.pgpass

TO CHECK EXISTING TABLES:
\dt

TO CREATE TABLE:
CREATE SCHEMA toponyms;

TO QUIT
\q

TO RUN THE CODE IN db/schema.sql
psql -h db.doc.ic.ac.uk -p 5432 -U at2225 -d at2225 -f db/schema.sql

TO CHANGE PATH
SET search_path TO toponyms;

SCHEMA
toponyms

TABLES
toponyms.entries

OTHER COMMANDS
SELECT * FROM toponyms.entries LIMIT 10;